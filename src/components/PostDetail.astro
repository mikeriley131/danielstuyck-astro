---
import { Image } from 'astro:assets';

import { getAllPosts } from '../lib/api';

interface PortfolioImage {
  portfolioImage: {
    node: {
      filePath: string;
    }
  }
}

interface Post {
  title: string;
  categories: {
    nodes: {
      name: string;
    }[];
  };
  slug: string;
  featuredImage: {
    node: {
      filePath: string;
    }
  }
  portfolioItemFields: {
    portfolioAwards: string;
    portfolioDirectors: string;
    portfolioImages: {
      portfolioImage: PortfolioImage[];
    };
    portfolioRole: string;
    previewText: string;
  }
}

const { slug } = Astro.props;

const getPostBySlug = async (slug: string) => {
  const allPosts = await getAllPosts();
  return allPosts.find((post: Post) => post.slug === slug);
};

const pageData = await getPostBySlug(slug);
---
<div class="detail-page">
  <button class="detail-page__featured-image-button" aria-label="View next image">
    <Image id="featured-image" class="detail-page__featured-image" src={`${import.meta.env.PUBLIC_WP_URL}${pageData.featuredImage.node.filePath}`} alt={`still from ${pageData.title}`} width="910" height="508" />
  </button>

  <ul class="detail-page__image-list" role="list">
    {pageData.portfolioItemFields.portfolioImages.map((image: PortfolioImage, index: number) => (
      <li>
        <button class="detail-page__image-list-button" id={`button-${index + 1}`} aria-label={`View image ${index + 1} as the featured image`}>
          <Image class="detail-page__image-list-image" src={`${import.meta.env.PUBLIC_WP_URL}${image?.portfolioImage?.node?.filePath}`} alt="" id={`img-${index + 1}`} width="82" height="46" />
        </button>
      </li>
      ))}
  </ul>

  <div class="detail-page__text-content">
    <h1 class="detail-page__heading">{pageData.title}</h1>
    <p class="detail-page__copy">{pageData.portfolioItemFields.portfolioDirectors}</p>
    <p class="detail-page__copy">{pageData.portfolioItemFields.portfolioRole}</p>
    <p class="detail-page__copy detail-page__copy--awards" set:html={pageData.portfolioItemFields.portfolioAwards} />
    <button class="detail-page__back-button" id="backButton" aria-label="Go back to the category page">
      <img src={`${import.meta.env.PUBLIC_WP_URL}/wp-content/themes/stuyck/images/icon-back-yellow.png`} alt=""/>
    </button>
  </div>
</div>

<script>
  import { myState } from '../store/state.js'

  document.querySelectorAll('.detail-page__image-list button').forEach((btn) => {
    btn.addEventListener('click', () => {
      const img = btn.querySelector('img');
      if (img && img.id) myState.featuredImg = img.id;
    });
  });

  const featuredButton = document.querySelector('.detail-page__featured-image-button');
  featuredButton?.addEventListener('click', () => {
    const imageEls = Array.from(document.querySelectorAll('.detail-page__image-list img')) as HTMLImageElement[];
    if (!imageEls.length) return;

    const featuredImage = document.getElementById('featured-image') as HTMLImageElement;

    let currentIndex = -1;
    if (myState.featuredImg) {
      const match = myState.featuredImg.match(/img-(\d+)/);
      if (match) currentIndex = parseInt(match[1], 10) - 1;
    }

    if (currentIndex === -1 && featuredImage) {
      currentIndex = imageEls.findIndex(img => img.src === featuredImage.src);
    }

    if (currentIndex === -1) currentIndex = 0;
    const nextIndex = (currentIndex + 1) % imageEls.length;
    const nextId = imageEls[nextIndex].id;
    if (nextId) myState.featuredImg = nextId;
  });

  function updateActiveThumbnail() {
    const thumbnails = Array.from(document.querySelectorAll('.detail-page__image-list-image')) as HTMLImageElement[];
    thumbnails.forEach(img => {
      if (img.id === myState.featuredImg) {
        img.classList.add('detail-page__image-list-image--active');
      } else {
        img.classList.remove('detail-page__image-list-image--active');
      }
    });
  }

  myState.listen(() => {
    const featuredImage = document.getElementById('featured-image')  as HTMLImageElement;
    const newImage = document.getElementById(myState.featuredImg) as HTMLImageElement;
    if (featuredImage && newImage) {
      featuredImage.src = newImage.src;

      document.startViewTransition(() => {
        featuredImage.src = newImage.src;
      });
      updateActiveThumbnail();
    }
  });

  // Set initial active thumbnail on page load
  updateActiveThumbnail();

  const backButton = document.getElementById('backButton');
  backButton?.addEventListener('click', () => {
    history.back();
  });
</script>