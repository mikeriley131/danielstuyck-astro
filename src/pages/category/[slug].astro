---
import { Image } from 'astro:assets';

import { getAllCategoriesWithSlugs, getAllPosts } from '../../lib/api';

import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro';

interface Post {
  title: string;
  categories: {
    nodes: {
      name: string;
    }[];
  };
  featuredImage: {
    node: {
      filePath: string;
      sourceUrl: string;
    }
  }
  portfolioItemFields: {
    previewText: string;
  }
  slug: string;
}

export async function getStaticPaths() {
  const pagesWithSlugs = await getAllCategoriesWithSlugs();
  return pagesWithSlugs.edges.map(({ node }: { node: { slug: string } }) => {
    return {
      params: { slug: node.slug },
    };
  });
}

const { slug }: { slug: string } = Astro.params;
const cleanSlug = slug.replace(/-/g, " ");

const getPostsByCategory = async (categoryName?: string) => {
  const allPosts = await getAllPosts();
  return allPosts.filter((post: Post) => post.categories.nodes[0].name === categoryName);
};

const categoryPosts = await getPostsByCategory(cleanSlug);
---
<Layout>
  <Header />
  <article class="content category">
    <div class="inner-content">
      <h1 class="sr-only" set:html={slug} />
      <ul role="list" class="category__list">
        <li class="category__item">
          {cleanSlug === 'colorist' ?
            (
              <button id="openDialogBtn" class="category__reel-button" command="show-modal" commandfor="reelDialog">
                <div class="category__reel-container">
                  <p class="category__reel-text">colorist reel</p>
                </div>
                <p class="category__item-title category__item-link">Colorist Reel</p>
              </button>
            )
          :
            (
              <a class="category__reel-link" href="https://vimeo.com/106631469">
                <div class="category__reel-container">
                  <p class="category__reel-text">title design work samples</p>
                </div>
              </a>
              <p class="category__item-title"><a class="category__item-link" href="https://vimeo.com/106631469">Title Design Work Samples</a></p>
            )
          }
        </li>
        {categoryPosts.map((post: Post) => (
          <li class="category__item">
            {post.featuredImage && (
              <a class="category__reel-container" href={`/${post.slug}`}>
                <Image
                  src={post.featuredImage.node.sourceUrl}
                  alt={`still from ${post.title}`} width="240" height="146" />
              </a>
            )}
            {post.portfolioItemFields.previewText && (
              <a class="category__item-link" href={`/${post.slug}`}>
                <div class="category__item-title previewText" set:html={post.portfolioItemFields.previewText} />
              </a>
            )}
            {!post.portfolioItemFields.previewText && (
              <p class="category__item-title">
                <a class="category__item-link noPreviewText" href={`/${post.slug}`}>{post.title}</a>
              </p>
            )}
          </li>
        ))}
      </ul>
      <dialog id="reelDialog">
        <button id="closeDialogBtn" commandfor="reelDialog" command="close" aria-label="Close dialog">x</button>
        <div style="padding:56.25% 0 0 0;position:relative;">
          <iframe src="https://player.vimeo.com/video/37415884?badge=0&amp;autopause=0&amp;player_id=0&amp;app_id=58479" allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share" referrerpolicy="strict-origin-when-cross-origin" style="position:absolute;top:0;left:0;width:100%;height:100%;" title="Color Reel // 2024"></iframe>
        </div>
        <script src="https://player.vimeo.com/api/player.js"></script>
      </dialog>
    </div>
  </article>
</Layout>

<script>
  import dialogPolyfill from 'dialog-polyfill';

  const dialog = document.getElementById('reelDialog') as HTMLDialogElement;
  const openButton = document.getElementById('openDialogBtn');
  const closeButton = document.getElementById('closeDialogBtn');

  if (!window.HTMLDialogElement) {
    dialogPolyfill.registerDialog(dialog);
  }

  openButton?.addEventListener('click', () => {
    dialog?.showModal();
  });

  closeButton?.addEventListener('click', () => {
    dialog.close();
  });
</script>
